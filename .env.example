# FishBoss Storage Paths
# All data stored under ~/.fishboss by default

# Base storage root
FISHBOSS_ROOT=~/.fishboss

# Server configuration
PORT=6577
HOST=0.0.0.0

# Environment
NODE_ENV=development

# Server secret - used for internal data encryption (NOT for login)
# Generate a random string: openssl rand -hex 32
SERVER_SECRET=your-secret-here

# CORS - whitelist for frontend origins
CORS_ORIGINS=http://localhost:6500

# --- Admin Authentication ---

# Bootstrap token - if set, first-time admin setup requires this value
# BOOTSTRAP_TOKEN=

# Restrict bootstrap to localhost only (default: true)
# AUTH_BOOTSTRAP_LOCALHOST_ONLY=true

# Session idle timeout in days (default: 7)
# AUTH_IDLE_TIMEOUT_DAYS=7

# Session absolute timeout in days (default: 30)
# AUTH_ABSOLUTE_TIMEOUT_DAYS=30

# Session cookie name (default: fishboss_session)
# AUTH_COOKIE_NAME=fishboss_session

# --- Reverse Proxy Trust ---
# Controls how Fastify resolves client IP from proxy headers.
# Accepted values:
#   false       - (default) direct connection, ignore X-Forwarded-For
#   true        - alias for 'loopback', trust only loopback proxies (127.0.0.1/::1)
#   loopback    - trust loopback proxies only
#   <number>    - trust the first N hops
#   <ip/cidr>   - trust specific proxy IP or CIDR (comma-separated for multiple)
# Examples:
#   TRUST_PROXY=false
#   TRUST_PROXY=loopback
#   TRUST_PROXY=10.0.0.0/8
#   TRUST_PROXY=10.0.0.1,10.0.0.2
# TRUST_PROXY=false
