{
  "name": "fishboss",
  "version": "0.1.0",
  "description": "AI agent orchestration platform with conversations, tools, agents, workflows, and MCP support",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file .env src/bootstrap.ts",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bootstrap.js"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "argon2": "^0.31.2",
    "fastify": "^5.2.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^2.0.0"
  }
}
